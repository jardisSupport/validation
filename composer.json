{
    "name": "jardissupport/validation",
    "homepage": "https://docs.jardis.io/en/support/validation",
    "description": "Object graph validation with recursive traversal, 21 built-in validators, and fluent field rule composition",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Validation\\Tests\\": "tests/"
        }
    },    "support": {
        "issues": "https://github.com/jardisSupport/validation/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "validation",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
