{
    "name": "jardissupport/validation",
    "homepage": "https://jardis.io",
    "description": "Object graph validation with recursive traversal, 21 built-in validators, and fluent field rule composition",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "phpstan/phpstan": "2.2.5",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Validation\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisSupport/validation/issues",
        "docs": "https://docs.jardis.io/en/support/validation",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "validation",
        "validator",
        "object-validation",
        "domain-driven-design",
        "php",
        "jardis",
        "headgent"
    ]
}
